# Example environment variables for e-commerce-backend
# Copy this file to .env and fill values for local development or production.

# If you use a full Mongo URI (recommended for local dev):
# MONGO_URI=mongodb://localhost:27017/fedecommerce

# Or provide Atlas credentials (less recommended for local files):
# MONGO_USERNAME=yourAtlasUser
# MONGO_PW=yourAtlasPassword

PORT=8080
STRIPE_SECRET=
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=
